rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function for admin check
    function isAdmin() { 
      return request.auth != null && (
        request.auth.token.get('email', '') == "sartawset@gmail.com" || 
        request.auth.token.get('email', '') == "yelwinaung9981@gmail.com" ||
        request.auth.token.get('email', '') == "saphosaung@gmail.com" ||
        request.auth.uid == "1wn3Vxg5n2O2QJsoKZiue9673oG2" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // --- USER PROFILE & DETAILS ---
    // Make profile and its subcollections readable/writable by all to avoid mapping/auth sync issues
    match /users/{phone} {
      allow read, write: if true;

      match /addresses/{id} { allow read, write: if true; } 
      match /sessions/{id} { allow read, write: if true; }
      match /pointTransactions/{id} { allow read, write: if true; }
      match /notifications/{id} { allow read, write: if true; }
    }

    match /authToPhone/{authUid} {
      allow read, write: if true;
    }

    // --- ORDERS ---
    // Allow read, write by all to handle guest orders and history queries flawlessly
    match /orders/{orderId} {
      allow read, write: if true;
    }

    // --- PRODUCTS & INVENTORIES ---
    match /products/{id} { 
      allow read, write: if true; 
    }

    // --- STATIC & GLOBAL READS ---
    match /categories/{id} { allow read, write: if true; }
    match /serviceAreas/{id} { allow read, write: if true; }
    match /settings/{id} { allow read, write: if true; }
    match /coupons/{id} { allow read, write: if true; }
    match /deals/{id} { allow read, write: if true; }
    match /bundles/{id} { allow read, write: if true; }
    match /broadcastNotifications/{id} { allow read, write: if true; }
    match /promotionBanners/{id} { allow read, write: if true; }
    
    // --- ADMINISTRATIVE & RIDERS ---
    match /admins/{id} { 
      allow read, write: if true;
    }
    match /auditLogs/{id} { 
      allow read, write: if true;
    }
    match /riders/{id} {
      allow read, write: if true;
    }

    match /test/{id} { allow read, write: if true; }
  }
}
